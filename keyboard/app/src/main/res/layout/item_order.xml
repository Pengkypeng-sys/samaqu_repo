<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?android:attr/selectableItemBackground">

    <View android:layout_width="3dp" android:layout_height="28dp"
        android:background="#FFEA580C" android:layout_marginEnd="12dp" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/txtBuyer"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FF111111" android:textSize="13sp" android:textStyle="bold" />
        <TextView android:id="@+id/txtOrderId"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FF999999" android:textSize="11sp" android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Kirim ›" android:textSize="11sp" android:textColor="#FF1D4ED8" android:textStyle="bold" />

</LinearLayout>
