<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="🧾 Buat Invoice"
                android:textSize="15sp" android:textStyle="bold"
                android:textColor="#FF111111"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp" />

            <!-- Pembeli -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/field_bg_light" android:layout_marginBottom="8dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                    android:text="Pembeli" android:textColor="#FF6B7280" android:textSize="12sp" android:paddingStart="12dp"/>
                <EditText android:id="@+id/etBuyer" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@null" android:paddingEnd="12dp"
                    android:textColor="#FF111111" android:textColorHint="#FFBBBBBB" android:textSize="13sp"
                    android:hint="Nama pembeli" android:singleLine="true"/>
            </LinearLayout>

            <!-- Produk -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/field_bg_light" android:layout_marginBottom="8dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                    android:text="Produk" android:textColor="#FF6B7280" android:textSize="12sp" android:paddingStart="12dp"/>
                <EditText android:id="@+id/etProduct" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@null" android:paddingEnd="12dp"
                    android:textColor="#FF111111" android:textColorHint="#FFBBBBBB" android:textSize="13sp"
                    android:hint="Nama produk" android:singleLine="true"/>
            </LinearLayout>

            <!-- Qty + Harga -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/field_bg_light" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content"
                        android:text="Qty" android:textColor="#FF6B7280" android:textSize="11sp" android:paddingStart="10dp"/>
                    <EditText android:id="@+id/etQty" android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="@null" android:paddingEnd="8dp"
                        android:textColor="#FF111111" android:textSize="13sp" android:hint="1"
                        android:textColorHint="#FFBBBBBB" android:inputType="number" android:singleLine="true"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/field_bg_light">
                    <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                        android:text="Harga" android:textColor="#FF6B7280" android:textSize="11sp" android:paddingStart="10dp"/>
                    <EditText android:id="@+id/etPrice" android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="@null" android:paddingEnd="8dp"
                        android:textColor="#FF111111" android:textSize="13sp" android:hint="0"
                        android:textColorHint="#FFBBBBBB" android:inputType="number" android:singleLine="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Ongkir + Kurir -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/field_bg_light" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="50dp" android:layout_height="wrap_content"
                        android:text="Ongkir" android:textColor="#FF6B7280" android:textSize="11sp" android:paddingStart="10dp"/>
                    <EditText android:id="@+id/etOngkir" android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="@null" android:paddingEnd="8dp"
                        android:textColor="#FF111111" android:textSize="13sp" android:hint="0"
                        android:textColorHint="#FFBBBBBB" android:inputType="number" android:singleLine="true"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/field_bg_light">
                    <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="Kurir" android:textColor="#FF6B7280" android:textSize="11sp" android:paddingStart="10dp"/>
                    <Spinner android:id="@+id/spShipping"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="@null" android:paddingEnd="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Bank Transfer -->
            <TextView android:text="💳 Transfer via (opsional)"
                android:textSize="12sp" android:textColor="#FF6B7280"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <TextView android:id="@+id/btnBCA" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="BCA" android:gravity="center" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#FFFFFFFF" android:background="@drawable/btn_bank_bca"
                    android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:tag="BCA"/>
                <TextView android:id="@+id/btnBRI" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="BRI" android:gravity="center" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#FFFFFFFF" android:background="@drawable/btn_bank_bri"
                    android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:tag="BRI"/>
                <TextView android:id="@+id/btnBNI" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="BNI" android:gravity="center" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#FFFFFFFF" android:background="@drawable/btn_bank_bni"
                    android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:tag="BNI"/>
                <TextView android:id="@+id/btnMandiri" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="MND" android:gravity="center" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#FFFFFFFF" android:background="@drawable/btn_bank_mandiri"
                    android:clickable="true" android:focusable="true" android:tag="Mandiri"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:id="@+id/btnBSI" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="BSI" android:gravity="center" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#FFFFFFFF" android:background="@drawable/btn_bank_bsi"
                    android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:tag="BSI"/>
                <TextView android:id="@+id/btnDANA" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="DANA" android:gravity="center" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#FFFFFFFF" android:background="@drawable/btn_bank_dana"
                    android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:tag="DANA"/>
                <TextView android:id="@+id/btnOVO" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="OVO" android:gravity="center" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#FFFFFFFF" android:background="@drawable/btn_bank_ovo"
                    android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:tag="OVO"/>
                <View android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"/>
            </LinearLayout>

            <!-- Bank Detail -->
            <LinearLayout android:id="@+id/bankFields"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/field_bg_light" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:id="@+id/tvBankNoLabel"
                        android:text="No. Rekening" android:textColor="#FF6B7280" android:textSize="11sp" android:paddingStart="12dp"/>
                    <EditText android:id="@+id/etBankNo" android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="@null" android:paddingEnd="12dp"
                        android:textColor="#FF111111" android:textColorHint="#FFBBBBBB" android:textSize="13sp"
                        android:hint="No. rekening / No. HP" android:singleLine="true" android:inputType="number"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/field_bg_light">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Atas Nama" android:textColor="#FF6B7280" android:textSize="11sp" android:paddingStart="12dp"/>
                    <EditText android:id="@+id/etBankHolder" android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="@null" android:paddingEnd="12dp"
                        android:textColor="#FF111111" android:textColorHint="#FFBBBBBB" android:textSize="13sp"
                        android:hint="Nama pemilik rekening" android:singleLine="true"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:id="@+id/btnGenerate"
                android:layout_width="match_parent" android:layout_height="46dp"
                android:background="@drawable/btn_blue_bg"
                android:text="📋 Generate Invoice"
                android:textColor="#FFFFFFFF" android:textSize="14sp" android:textStyle="bold"
                android:gravity="center" android:clickable="true" android:focusable="true" />
        </LinearLayout>

        <!-- Hasil Invoice -->
        <LinearLayout android:id="@+id/resultCard"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_bg"
            android:padding="16dp" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Hasil Invoice" android:textColor="#FF111111" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:id="@+id/btnCopy"
                    android:layout_width="wrap_content" android:layout_height="34dp"
                    android:background="@drawable/btn_blue_bg"
                    android:text="  Salin  " android:textColor="#FFFFFFFF" android:textSize="12sp" android:textStyle="bold"
                    android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:clickable="true" android:focusable="true" />
            </LinearLayout>
            <EditText android:id="@+id/etResult"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/field_bg_light" android:padding="12dp"
                android:textColor="#FF111111" android:textSize="12sp" android:fontFamily="monospace"
                android:inputType="textMultiLine" android:minLines="5" android:focusable="false" />
        </LinearLayout>

        <EditText android:id="@+id/etPayment" android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone"/>
        <EditText android:id="@+id/etAddress" android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone"/>
    </LinearLayout>
</ScrollView>
