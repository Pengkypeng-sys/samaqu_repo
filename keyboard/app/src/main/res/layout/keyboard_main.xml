<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FF1A1F2E">

    <!-- ══ TOOLBAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:background="#FF1D4ED8"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <LinearLayout android:id="@+id/btnInvoice"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_tb_invoice" android:layout_marginBottom="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Invoice" android:textColor="#CCFFFFFF" android:textSize="7.5sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="22dp" android:background="#FFDDDDDD"/>

        <LinearLayout android:id="@+id/btnOngkir"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_tb_ongkir" android:layout_marginBottom="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ongkir" android:textColor="#CCFFFFFF" android:textSize="7.5sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="22dp" android:background="#FFDDDDDD"/>

        <LinearLayout android:id="@+id/btnAutoText"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_tb_autotext" android:layout_marginBottom="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Auto Text" android:textColor="#CCFFFFFF" android:textSize="7.5sp" android:textStyle="bold"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="22dp" android:background="#FFDDDDDD"/>

        <LinearLayout android:id="@+id/btnPending"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_tb_pending" android:layout_marginBottom="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pending" android:textColor="#CCFFFFFF" android:textSize="7.5sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="22dp" android:background="#FFDDDDDD"/>

        <LinearLayout android:id="@+id/btnDashboard"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_tb_dashboard" android:layout_marginBottom="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dashboard" android:textColor="#CCFFFFFF" android:textSize="7.5sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="22dp" android:background="#FFDDDDDD"/>

        <LinearLayout android:id="@+id/btnSync"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_tb_sync" android:layout_marginBottom="2dp"/>
            <TextView android:id="@+id/syncStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sync" android:textColor="#CCFFFFFF" android:textSize="7.5sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══ PANEL AUTO TEXT ══ -->
    <LinearLayout android:id="@+id/templatePanel"
        android:layout_width="match_parent" android:layout_height="@dimen/panel_height"
        android:orientation="vertical" android:background="#FF1E2536" android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
            android:background="#FF252D3E" android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="6dp" android:orientation="horizontal">
            <HorizontalScrollView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:scrollbars="none">
                <LinearLayout android:id="@+id/categoryTabs" android:layout_width="wrap_content" android:layout_height="match_parent"
                    android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="4dp" android:paddingEnd="4dp" />
            </HorizontalScrollView>
            <TextView android:id="@+id/btnClosePanel" android:layout_width="36dp" android:layout_height="36dp"
                android:text="✕" android:textSize="14sp" android:textColor="#FF999999"
                android:gravity="center" android:clickable="true" android:focusable="true" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF2D3548"/>

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/templateList"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:background="#FF1E2536" />
    </LinearLayout>

    <!-- ══ PANEL INVOICE ══ -->
    <LinearLayout android:id="@+id/invoicePanel"
        android:layout_width="match_parent" android:layout_height="@dimen/invoice_panel_height"
        android:orientation="vertical" android:background="#FF1E2536" android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
            android:background="#FF1D2D4A" android:gravity="center_vertical"
            android:paddingStart="14dp" android:paddingEnd="6dp" android:orientation="horizontal">
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_tb_invoice" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Buat Invoice" android:textColor="#FF1D4ED8" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:id="@+id/btnCloseInvoice" android:layout_width="36dp" android:layout_height="36dp"
                android:text="✕" android:textSize="14sp" android:textColor="#FF999999"
                android:gravity="center" android:clickable="true" android:focusable="true" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF2D3548"/>

        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="10dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                        <TextView android:text="Pembeli" android:textColor="#FFAAAACC" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="3dp"/>
                        <EditText android:id="@+id/invBuyer" android:layout_width="match_parent" android:layout_height="38dp"
                            android:background="@drawable/field_bg_light" android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:textColor="#FFEEEEEE" android:textColorHint="#FF666888" android:textSize="12sp" android:hint="Nama pembeli" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="4dp">
                        <TextView android:text="Produk" android:textColor="#FFAAAACC" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="3dp"/>
                        <EditText android:id="@+id/invProduct" android:layout_width="match_parent" android:layout_height="38dp"
                            android:background="@drawable/field_bg_light" android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:textColor="#FFEEEEEE" android:textColorHint="#FF666888" android:textSize="12sp" android:hint="Nama produk" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Qty + Harga -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                        <TextView android:text="Qty" android:textColor="#FFAAAACC" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="3dp"/>
                        <EditText android:id="@+id/invQty" android:layout_width="match_parent" android:layout_height="38dp"
                            android:background="@drawable/field_bg_light" android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:textColor="#FFEEEEEE" android:textColorHint="#FF666888" android:textSize="12sp" android:hint="1" android:inputType="number" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="4dp">
                        <TextView android:text="Harga (Rp)" android:textColor="#FFAAAACC" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="3dp"/>
                        <EditText android:id="@+id/invPrice" android:layout_width="match_parent" android:layout_height="38dp"
                            android:background="@drawable/field_bg_light" android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:textColor="#FFEEEEEE" android:textColorHint="#FF666888" android:textSize="12sp" android:hint="0" android:inputType="text" android:digits="0123456789." />
                    </LinearLayout>
                </LinearLayout>

                <!-- Jasa Kirim + Ongkir -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                        <TextView android:text="Jasa Kirim" android:textColor="#FFAAAACC" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="3dp"/>
                        <Spinner android:id="@+id/invShipping"
                            android:layout_width="match_parent" android:layout_height="38dp"
                            android:background="@drawable/field_bg_light"
                            android:paddingStart="10dp" android:paddingEnd="6dp"
                            android:textColor="#FFEEEEEE" android:textSize="12sp"
                            android:gravity="center_vertical"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="4dp">
                        <TextView android:text="Ongkir (Rp)" android:textColor="#FFAAAACC" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="3dp"/>
                        <EditText android:id="@+id/invOngkir" android:layout_width="match_parent" android:layout_height="38dp"
                            android:background="@drawable/field_bg_light" android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:textColor="#FFEEEEEE" android:textColorHint="#FF666888" android:textSize="12sp" android:hint="0" android:inputType="text" android:digits="0123456789." />
                    </LinearLayout>
                </LinearLayout>

                <!-- Bank transfer section -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="18dp" android:layout_height="12dp"
                        android:background="#FFDDAA00" android:layout_marginEnd="6dp"/>
                    <TextView android:text="Transfer via (opsional)" android:textSize="10sp"
                        android:textColor="#FFAAAACC"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <TextView android:id="@+id/imbBca" android:layout_width="0dp" android:layout_height="32dp"
                        android:layout_weight="1" android:text="BCA" android:gravity="center"
                        android:textSize="11sp" android:textColor="#FFFFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_bank_bca" android:layout_marginEnd="3dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/imbBri" android:layout_width="0dp" android:layout_height="32dp"
                        android:layout_weight="1" android:text="BRI" android:gravity="center"
                        android:textSize="11sp" android:textColor="#FFFFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_bank_bri" android:layout_marginEnd="3dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/imbBni" android:layout_width="0dp" android:layout_height="32dp"
                        android:layout_weight="1" android:text="BNI" android:gravity="center"
                        android:textSize="11sp" android:textColor="#FFFFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_bank_bni" android:layout_marginEnd="3dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/imbMandiri" android:layout_width="0dp" android:layout_height="32dp"
                        android:layout_weight="1" android:text="MND" android:gravity="center"
                        android:textSize="11sp" android:textColor="#FFFFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_bank_mandiri"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/imbBsi" android:layout_width="0dp" android:layout_height="32dp"
                        android:layout_weight="1" android:text="BSI" android:gravity="center"
                        android:textSize="11sp" android:textColor="#FFFFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_bank_bsi" android:layout_marginEnd="3dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/imbDana" android:layout_width="0dp" android:layout_height="32dp"
                        android:layout_weight="1" android:text="DANA" android:gravity="center"
                        android:textSize="11sp" android:textColor="#FFFFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_bank_dana" android:layout_marginEnd="3dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/imbOvo" android:layout_width="0dp" android:layout_height="32dp"
                        android:layout_weight="1" android:text="OVO" android:gravity="center"
                        android:textSize="11sp" android:textColor="#FFFFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_bank_ovo" android:layout_marginEnd="3dp"
                        android:clickable="true" android:focusable="true"/>
                    <View android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"/>
                </LinearLayout>

                <!-- Bank no (muncul setelah pilih bank) -->
                <LinearLayout android:id="@+id/imbFields" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:visibility="gone" android:layout_marginBottom="8dp">
                    <EditText android:id="@+id/imbNo" android:layout_width="match_parent" android:layout_height="38dp"
                        android:background="@drawable/field_bg_light" android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:textColor="#FFEEEEEE" android:textColorHint="#FF666888" android:textSize="12sp"
                        android:hint="Nomor rekening" android:inputType="number" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/imbHolder" android:layout_width="match_parent" android:layout_height="38dp"
                        android:background="@drawable/field_bg_light" android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:textColor="#FFEEEEEE" android:textColorHint="#FF666888" android:textSize="12sp"
                        android:hint="Nama pemilik rekening"/>
                </LinearLayout>

                <TextView android:id="@+id/invBtnGenerate"
                    android:layout_width="match_parent" android:layout_height="42dp"
                    android:background="@drawable/btn_blue_bg"
                    android:text="📋 Generate Invoice"
                    android:textColor="#FFFFFFFF" android:textSize="13sp" android:textStyle="bold"
                    android:gravity="center" android:clickable="true" android:focusable="true" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ══ PANEL PENDING ══ -->
    <LinearLayout android:id="@+id/pendingPanel"
        android:layout_width="match_parent" android:layout_height="@dimen/panel_height"
        android:orientation="vertical" android:background="#FF1E2536" android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
            android:background="#FF1D2D4A" android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="6dp" android:orientation="horizontal">
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_tb_pending" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Pending — Minta Bukti Transfer" android:textColor="#FF1D4ED8" android:textSize="12sp" android:textStyle="bold" />
            <TextView android:id="@+id/btnClosePending" android:layout_width="36dp" android:layout_height="36dp"
                android:text="✕" android:textSize="14sp" android:textColor="#FF999999"
                android:gravity="center" android:clickable="true" android:focusable="true" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF2D3548"/>

        <TextView android:id="@+id/pendingEmpty"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Tidak ada order pending"
            android:textColor="#FFAAAAAA" android:textSize="13sp"
            android:gravity="center" android:padding="20dp" android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/pendingList"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:background="#FF1E2536" />
    </LinearLayout>

    <!-- ══ PANEL EMOJI ══ -->
    <LinearLayout android:id="@+id/emojiPanel"
        android:layout_width="match_parent" android:layout_height="@dimen/panel_height"
        android:orientation="vertical" android:background="#FF1E2536" android:visibility="gone">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
            android:background="#FF252D3E" android:gravity="center_vertical"
            android:paddingStart="14dp" android:paddingEnd="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Emoji" android:textColor="#FF1D4ED8" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:id="@+id/btnCloseEmoji" android:layout_width="36dp" android:layout_height="36dp"
                android:text="✕" android:textSize="14sp" android:textColor="#FF999999"
                android:gravity="center" android:clickable="true" android:focusable="true"/>
        </LinearLayout>

        <!-- Tabs kategori -->
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="34dp"
            android:background="#FF1E2536" android:scrollbars="none">
            <LinearLayout android:id="@+id/emojiCategoryTabs"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="6dp" android:paddingEnd="6dp"/>
        </HorizontalScrollView>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF2D3548"/>

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/emojiList"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:padding="4dp"/>
    </LinearLayout>

    <!-- ══ PANEL WEBVIEW ══ -->
    <LinearLayout android:id="@+id/webPanel"
        android:layout_width="match_parent" android:layout_height="@dimen/web_panel_height"
        android:orientation="vertical" android:background="#FF1E2536" android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
            android:background="#FF1D2D4A" android:gravity="center_vertical"
            android:paddingStart="14dp" android:paddingEnd="6dp" android:orientation="horizontal">
            <TextView android:id="@+id/webPanelTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Cek Ongkir" android:textColor="#FF1D4ED8" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:id="@+id/btnCloseWeb" android:layout_width="36dp" android:layout_height="36dp"
                android:text="✕" android:textSize="14sp" android:textColor="#FF999999"
                android:gravity="center" android:clickable="true" android:focusable="true" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF2D3548"/>

        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="10dp">

            <!-- Asal -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/field_bg_light" android:layout_marginBottom="4dp">
                <TextView android:layout_width="46dp" android:layout_height="wrap_content"
                    android:text="Asal" android:textColor="#FF6B7280" android:textSize="11sp" android:paddingStart="10dp"/>
                <EditText android:id="@+id/oqOrigin" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@null" android:paddingEnd="8dp"
                    android:textColor="#FFEEEEEE" android:textColorHint="#FFBBBBBB" android:textSize="12sp"
                    android:hint="Cari kota asal..." android:singleLine="true" android:imeOptions="actionNext"
                    android:inputType="text"/>
            </LinearLayout>
            <ListView android:id="@+id/oqOriginList" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="#FF1E2536"
                android:visibility="gone" android:divider="#FFE2E8F0" android:dividerHeight="1dp"
                android:layout_marginBottom="4dp"/>

            <!-- Tujuan -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/field_bg_light" android:layout_marginBottom="4dp">
                <TextView android:layout_width="46dp" android:layout_height="wrap_content"
                    android:text="Tujuan" android:textColor="#FF6B7280" android:textSize="11sp" android:paddingStart="10dp"/>
                <EditText android:id="@+id/oqDest" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@null" android:paddingEnd="8dp"
                    android:textColor="#FFEEEEEE" android:textColorHint="#FFBBBBBB" android:textSize="12sp"
                    android:hint="Cari kota tujuan..." android:singleLine="true" android:imeOptions="actionNext"
                    android:inputType="text"/>
            </LinearLayout>
            <ListView android:id="@+id/oqDestList" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="#FF1E2536"
                android:visibility="gone" android:divider="#FFE2E8F0" android:dividerHeight="1dp"
                android:layout_marginBottom="4dp"/>

            <!-- Berat + Cek -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/field_bg_light" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="50dp" android:layout_height="wrap_content"
                        android:text="Berat(g)" android:textColor="#FF6B7280" android:textSize="10sp" android:paddingStart="8dp"/>
                    <EditText android:id="@+id/oqWeight" android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="@null" android:paddingEnd="8dp"
                        android:textColor="#FFEEEEEE" android:textSize="12sp" android:hint="1000"
                        android:textColorHint="#FFBBBBBB" android:inputType="number" android:singleLine="true"/>
                </LinearLayout>
                <TextView android:id="@+id/btnOqCek" android:layout_width="80dp" android:layout_height="36dp"
                    android:text="🔍 Cek" android:gravity="center" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#FFFFFFFF" android:background="@drawable/btn_blue_bg"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Status + Results -->
            <TextView android:id="@+id/oqStatus" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#FF6B7280" android:gravity="center"
                android:padding="8dp" android:visibility="gone"/>
            <LinearLayout android:id="@+id/oqResults" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"/>
        </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ══ KEYBOARD ══ -->
    <com.samaqu.keyboard.ime.SamaQuKeyboardView
        android:id="@+id/keyboardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:keyBackground="@drawable/key_bg"
        android:keyTextColor="#FFFFFFFF"
        android:keyTextSize="@dimen/key_text_size"
        android:shadowColor="#661D4ED8"
        android:shadowRadius="0"
        android:background="#FF1A1F2E"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:paddingStart="3dp"
        android:paddingEnd="3dp" />

</LinearLayout>
