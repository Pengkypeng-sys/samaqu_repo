<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="#FF1D4ED8"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:elevation="2dp">

            <View android:layout_width="4dp" android:layout_height="20dp" android:background="#FFFFFFFF" android:layout_marginEnd="10dp"/>
            <TextView
                android:text="Auto Text"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/txtHint"
                android:text="Tap untuk salin"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="#FF1A2540"
            android:scrollbars="none"
            android:elevation="1dp">
            <LinearLayout
                android:id="@+id/categoryTabs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </HorizontalScrollView>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF2D3548"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/templateList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FF1A1F2E" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTemplate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#FF1D4ED8"
        app:tint="#FFFFFFFF" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
