<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <inset android:insetLeft="2dp" android:insetRight="2dp" android:insetTop="1dp" android:insetBottom="1dp">
            <shape android:shape="rectangle">
                <solid android:color="#FF3D5A9E" />
                <corners android:radius="8dp" />
            </shape>
        </inset>
    </item>
    <item>
        <inset android:insetLeft="2dp" android:insetRight="2dp" android:insetTop="1dp" android:insetBottom="1dp">
            <layer-list>
                <item android:bottom="-2dp">
                    <shape android:shape="rectangle">
                        <solid android:color="#FF0D1117" />
                        <corners android:radius="8dp" />
                    </shape>
                </item>
                <item android:bottom="2dp">
                    <shape android:shape="rectangle">
                        <solid android:color="#FF2D3548" />
                        <stroke android:width="1dp" android:color="#44FFFFFF" />
                        <corners android:radius="8dp" />
                    </shape>
                </item>
            </layer-list>
        </inset>
    </item>
</selector>
